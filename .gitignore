# Wallpaper cache (large binary, changes frequently)
hypr/.config/hypr/wallpaper_effects/.wallpaper_current

# Claude session files
**/.claude/

# ...but DO track config from the claude stow package
!claude/.claude/
claude/.claude/*
!claude/.claude/settings.json
!claude/.claude/CLAUDE.md
!claude/.claude/.gitignore
!claude/.claude/.mcp.json
!claude/.claude/keybindings.json
!claude/.claude/statusline.sh
!claude/.claude/statusline-command.sh
!claude/.claude/the-security-guide.md
!claude/.claude/gitlab-activity-response-structure.md
!claude/.claude/rules
!claude/.claude/agents
!claude/.claude/commands
!claude/.claude/skills
.dmux-hooks/

# Nushell runtime/state files (local machine data)
nushell/.config/nushell/history.txt
nushell/.config/nushell/history.sqlite3
nushell/.config/nushell/*.sqlite3-shm
nushell/.config/nushell/*.sqlite3-wal

# Codex runtime/state (machine-local, regenerated by codex at runtime)
codex/.codex/tmp/
codex/.codex/memories/
# Added by code-review-graph
.code-review-graph/
