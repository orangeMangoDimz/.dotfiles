[
  // ============================================================================
  // Global Bindings (Apply to all contexts)
  // ============================================================================
  {
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "shift-alt-l": "workspace::IncreaseOpenDocksSize",
      "shift-alt-h": "workspace::DecreaseOpenDocksSize",
    },
  },

  // ============================================================================
  // Workspace Navigation
  // ============================================================================
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "shift-alt-l": "workspace::IncreaseOpenDocksSize",
      "shift-alt-h": "workspace::DecreaseOpenDocksSize",
      "ctrl-s": null,
      "ctrl-b": null,
    },
  },

  // ============================================================================
  // Vim Mode - Normal
  // ============================================================================
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // === DEBUGGING ===
      "space b t": "editor::ToggleBreakpoint",

      // === VIM MOTION OVERRIDES ===
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],

      // === FILE OPERATIONS (Space + F) ===
      "space f f": "file_finder::Toggle",
      "space f w": "pane::DeploySearch",
      "space f m": "editor::Format",
      "space f c": "project_panel::CollapseAllEntries",

      // === CODE ACTIONS (Space + C) ===
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c d": "diagnostics::Deploy",

      // === EXPLORER/PANELS (Space + E) ===
      "space e t": "workspace::ToggleLeftDock",
      "space e e": "project_panel::ToggleFocus",
      "space e p": "outline::Toggle",
      "space e a": "workspace::ToggleRightDock",

      // === WINDOW MANAGEMENT ===
      "space h": "pane::SplitRight",
      "space v": "pane::SplitDown",
      "space x": "pane::CloseActiveItem",
      "space w w": "editor::ToggleSoftWrap",

      // === PANE RESIZING ===
      "alt-shift-l": "vim::ResizePaneRight",
      "alt-shift-h": "vim::ResizePaneLeft",

      // === NAVIGATION (G prefix) ===
      "g b": "pane::GoBack",
      "g r": "editor::FindAllReferences",

      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",

      // === ERROR NAVIGATION ===
      "] e": "editor::GoToDiagnostic",
      "[ e": "editor::GoToPreviousDiagnostic",

      // === GIT - HUNK NAVIGATION ===
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      // === GIT - ACTIONS ===
      "space g h d": "editor::ToggleSelectedDiffHunks",
      "space g h r": "git::Restore",
      "space g h f": "git_panel::ToggleFocus",
      "space g d": "git::Diff",

      // === MARKDOWN ===
      "space m p": "markdown::OpenPreview",
      "space m P": "markdown::OpenPreviewToTheSide",

      // === NOTIFICATIONS ===
      "space n c": "workspace::ClearAllNotifications",
    },
  },

  // ============================================================================
  // Vim Mode - Visual
  // ============================================================================
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
      "s": ["vim::PushSneak", {}],
      "S": ["vim::PushSneakBackward", {}],
    },
  },

  // ============================================================================
  // Vim Mode - Insert
  // ============================================================================
  {
    "context": "vim_mode == insert",
    "bindings": {
      // "j j": "vim::NormalBefore"
    },
  },

  // ============================================================================
  // Terminal
  // ============================================================================
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-shift-j": "pane::ActivateNextItem",
      "ctrl-shift-k": "pane::ActivatePreviousItem",
      "ctrl-shift-f": "workspace::ToggleZoom",
      "alt-t": null,
    },
  },

  // ============================================================================
  // Project Panel (File Explorer)
  // ============================================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "q": "workspace::ToggleRightDock",
      "space e t": "workspace::ToggleLeftDock",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "enter": ["workspace::SendKeystrokes", "enter space e t"],
    },
  },

  // ============================================================================
  // Editor (Full Mode)
  // ============================================================================
  {
    "context": "(Editor && mode == full)",
    "bindings": {},
  },

  // ============================================================================
  // File Finder & Search
  // ============================================================================
  {
    "context": "((FileFinder || FileFinder > Picker > Editor) || FileFinder > Picker > menu)",
    "bindings": {},
  },
  {
    "context": "BufferSearchBar",
    "bindings": {},
  },

  // ============================================================================
  // Non-Terminal Contexts (Global Override)
  // ============================================================================
  {
    "context": "!Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-shift-c": null,
    },
  },

  // ============================================================================
  // Editor-Specific Overrides
  // ============================================================================
  {
    "context": "Editor",
    "bindings": {
      "f9": null,
    },
  },
]
